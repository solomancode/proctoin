{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@proctoin/source"],
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "noImplicitAny": false,
    "paths": {
      "@proctoin/ui": ["./libs/ui/src/index.ts"],
      "@proctoin/events": ["./libs/events/src/index.ts"]
    }
  }
}
